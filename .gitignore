# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ------------------------------------------------------------
# Environment / secrets
# ------------------------------------------------------------
.env
.env.*
!.env.example

# Common key/cert files (avoid committing secrets)
*.pem
*.key

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyd
*.so

# Virtual environments
.venv/
venv/
ENV/
env/

# Packaging / builds
build/
dist/
*.egg-info/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.cache/

# Jupyter
.ipynb_checkpoints/

# ------------------------------------------------------------
# Node / web
# ------------------------------------------------------------
node_modules/
coverage/

# Build outputs
.next/
out/
dist/
build/

# TypeScript
*.tsbuildinfo

# ------------------------------------------------------------
# IDEs / editors
# ------------------------------------------------------------
.idea/
*.iml

# VS Code (keep shared workspace config files)
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ------------------------------------------------------------
# Misc local folders
# ------------------------------------------------------------
.tmp/
tmp/
.temp/
temp/
.local/

# ADK Samples
/adk-samples/

#ignore all the samples in the samples folder
/samples/
/docs/

# ------------------------------------------------------------
# Android
# ------------------------------------------------------------

# Firebase config — download from Firebase Console, never commit
/android/app/google-services.json

# Gradle build outputs and caches
/android/.gradle/
/android/build/
/android/app/build/
/android/app/*.jks
/android/app/*.keystore
/android/app/release/

# Android Studio project files
/android/.idea/
/android/**/*.iml
/android/local.properties

# Capture files
/android/captures/

# ------------------------------------------------------------
# Python backend (gervis-backend)
# ------------------------------------------------------------

# Secrets / credentials — never commit
/gervis-backend/.env
/gervis-backend/serviceAccountKey.json
/gervis-backend/*-service-account*.json
/gervis-backend/*.json.secret

# uv virtual environment and cache
/gervis-backend/.venv/
/gervis-backend/.uv/

# Python cache
/gervis-backend/__pycache__/
/gervis-backend/**/__pycache__/
/gervis-backend/*.py[cod]

# Build / dist
/gervis-backend/dist/
/gervis-backend/build/
/gervis-backend/*.egg-info/

# Test / lint caches
/gervis-backend/.pytest_cache/
/gervis-backend/.mypy_cache/
/gervis-backend/.ruff_cache/