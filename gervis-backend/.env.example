# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=path/to/serviceAccountKey.json
# OR use GOOGLE_APPLICATION_CREDENTIALS env var for ADC

# JWT
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=720

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/spectalk
# For Cloud SQL with connector:
# DB_INSTANCE_CONNECTION_NAME=project:region:instance
# DB_NAME=spectalk
# DB_USER=spectalk_user
# DB_PASSWORD=your-db-password

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000
