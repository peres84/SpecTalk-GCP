# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_JSON=path/to/serviceAccountKey.json
# OR use GOOGLE_APPLICATION_CREDENTIALS env var for ADC

# JWT
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=720

# Database (Cloud SQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/spectalk
# For Cloud SQL with connector:
# DB_INSTANCE_CONNECTION_NAME=project:region:instance
# DB_NAME=spectalk
# DB_USER=spectalk_user
# DB_PASSWORD=your-db-password

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000"]

# Phase 3: Gemini Live + ADK
# Single key for everything: voice session, Google Search grounding, Google Maps grounding
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# ADK config
ADK_APP_NAME=spectalk
GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Tracing (optional)
# ENABLE_TRACING=opik        — send to Opik UI (recommended for dev)
# ENABLE_TRACING=console     — print spans to stdout
# ENABLE_TRACING=cloud       — send to Google Cloud Trace (production)
ENABLE_TRACING=console
# Opik (Comet) — https://www.comet.com → Settings → API Keys
# Set OPIK_API_KEY to enable Opik agent tracing (stores full turn text)
OPIK_API_KEY=your-opik-api-key
OPIK_WORKSPACE=javier-peres
OPIK_PROJECT_NAME=gervis

# Local dev / testing scripts (scripts/get_firebase_token.py, scripts/test_auth_session.py)
# Get FIREBASE_WEB_API_KEY from: Firebase Console → Project settings → General → Web API key
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=your-test-password
BACKEND_URL=http://localhost:8080
